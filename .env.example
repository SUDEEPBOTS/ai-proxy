# Port for your proxy server
PORT=3000

# Your real API key from the upstream provider (opencode.ai)
UPSTREAM_API_KEY=sk-your-real-upstream-key-here

# Comma-separated list of API keys you want to issue to YOUR users.
# Leave blank if you want the API to be public (not recommended).
ALLOWED_KEYS=sk-myuser1,sk-myuser2,sk-vip-user
